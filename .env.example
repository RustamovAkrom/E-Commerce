# ═══════════════════════════════════════════════════════════════════════════
#  E-Commerce Platform — production environment template
#  Copy: cp .env.example .env
#  Fill every value marked  ← CHANGE_ME  before running docker-compose up
#  NEVER commit .env to Git
# ═══════════════════════════════════════════════════════════════════════════

# ─── App core ───────────────────────────────────────────────────────────────
APP_NAME="E-Commerce Platform"
APP_VERSION="0.1.0"
DEBUG=false

# Min 32 chars. Generate:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=CHANGE_ME_min32chars_random_string

API_V1_PREFIX=/api/v1

# ─── Database (PostgreSQL) ──────────────────────────────────────────────────
POSTGRES_USER=ecommerce
POSTGRES_PASSWORD=CHANGE_ME_db_password
POSTGRES_DB=ecommerce

# ─── Redis ──────────────────────────────────────────────────────────────────
# Set a strong password — Redis without auth is open to the whole network
REDIS_PASSWORD=CHANGE_ME_redis_password

# ─── RabbitMQ ───────────────────────────────────────────────────────────────
RABBITMQ_USER=ecommerce
RABBITMQ_PASSWORD=CHANGE_ME_rabbitmq_password

# ─── MinIO / S3 storage ─────────────────────────────────────────────────────
MINIO_ACCESS_KEY=CHANGE_ME_minio_access_key
MINIO_SECRET_KEY=CHANGE_ME_minio_secret_key_min8chars
MINIO_BUCKET=ecommerce
MINIO_SECURE=true

# ─── CORS & hosts ───────────────────────────────────────────────────────────
# Replace with your actual domain
CORS_ORIGINS=["https://yourdomain.com"]
ALLOWED_HOSTS=["yourdomain.com","www.yourdomain.com"]

# ─── JWT ────────────────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000

# ─── Feature flags ──────────────────────────────────────────────────────────
# Platforma doimo multi-vendor marketplace — MARKETPLACE_MODE olib tashlandi.
ELASTICSEARCH_ENABLED=false
TELEGRAM_BOT_ENABLED=true

# ─── Superadmin (auto-created on first startup) ─────────────────────────────
# Platforma birinchi ishga tushganda shu ma'lumotlar bilan SUPERADMIN yaratiladi.
ADMIN_EMAIL=admin@example.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_admin_password
ADMIN_FULL_NAME=Super Admin
# /admin/db — ma'lumotlar bazasini boshqarish UI (faqat DEBUG=true yoki bu yoqilganda)
SQLADMIN_ENABLED=false

# ─── Payments ───────────────────────────────────────────────────────────────
# Click (Uzbekistan)
CLICK_SERVICE_ID=
CLICK_MERCHANT_ID=
CLICK_SECRET_KEY=

# Payme (Uzbekistan)
PAYME_ID=
PAYME_KEY=

# Stripe (international)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Notifications ──────────────────────────────────────────────────────────
# SMTP (email)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@yourdomain.com
SMTP_TLS=true

# Eskiz (Uzbekistan SMS)
ESKIZ_EMAIL=
ESKIZ_PASSWORD=

# ─── Telegram Bot ───────────────────────────────────────────────────────────
# Get token from @BotFather
BOT_TOKEN=CHANGE_ME_bot_token
# Your admin Telegram chat id (receives support messages)
ADMIN_CHAT_ID=0
# Random shared secret between bot and backend — generate same as SECRET_KEY
TELEGRAM_AUTH_SECRET=CHANGE_ME_telegram_auth_secret
# Webhook mode (prod) or polling (dev)
BOT_ENV=prod
WEBHOOK_BASE_URL=https://yourdomain.com
WEBHOOK_PATH=/telegram/webhook
# Random string for validating incoming Telegram webhook requests
WEBHOOK_SECRET=CHANGE_ME_webhook_secret

# ─── Frontend (Next.js public vars) ─────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://yourdomain.com
NEXT_PUBLIC_APP_NAME=E-Commerce
NEXT_PUBLIC_CURRENCY=UZS
NEXT_PUBLIC_LOCALE=uz-UZ
NEXT_PUBLIC_TELEGRAM_BOT=

# ─── Monitoring ─────────────────────────────────────────────────────────────
# Get DSN from https://sentry.io
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ─── Rate limiting ──────────────────────────────────────────────────────────
RATE_LIMIT_AUTH=5/minute
RATE_LIMIT_DEFAULT=100/minute
