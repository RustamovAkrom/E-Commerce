# ──────────────────────────────────────────────────────────────────────────
# E-Commerce Platform — environment template
# Copy to `.env` and fill in real values. Never commit `.env`.
# ──────────────────────────────────────────────────────────────────────────

# --- Core -------------------------------------------------------------------
APP_NAME="ECommerce Platform"
APP_VERSION="0.1.0"
DEBUG=false
# REQUIRED. Min 32 chars. Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY="change-me-to-a-secure-random-string-min-32-chars"
API_V1_PREFIX="/api/v1"
ALLOWED_HOSTS=["*"]
CORS_ORIGINS=["http://localhost:3000"]

# --- Feature flags ----------------------------------------------------------
MARKETPLACE_MODE=false
ELASTICSEARCH_ENABLED=false
TELEGRAM_BOT_ENABLED=true

# --- JWT --------------------------------------------------------------------
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000

# --- Database ---------------------------------------------------------------
DATABASE_URL="postgresql+asyncpg://postgres:postgres@postgres:5432/ecommerce"
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_ECHO=false

# --- Redis ------------------------------------------------------------------
REDIS_URL="redis://redis:6379/0"
CART_TTL_SECONDS=604800

# --- RabbitMQ / Celery ------------------------------------------------------
CELERY_BROKER_URL="amqp://guest:guest@rabbitmq:5672//"
CELERY_RESULT_BACKEND="redis://redis:6379/1"

# --- Storage (MinIO / S3) ---------------------------------------------------
MINIO_ENDPOINT="minio:9000"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="ecommerce"
MINIO_SECURE=false
MAX_UPLOAD_SIZE_BYTES=10485760

# --- Elasticsearch ----------------------------------------------------------
ELASTICSEARCH_URL="http://elasticsearch:9200"

# --- Payments ---------------------------------------------------------------
CLICK_SERVICE_ID=""
CLICK_MERCHANT_ID=""
CLICK_SECRET_KEY=""
PAYME_ID=""
PAYME_KEY=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# --- Notifications ----------------------------------------------------------
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="no-reply@example.com"
SMTP_TLS=true
ESKIZ_EMAIL=""
ESKIZ_PASSWORD=""
ESKIZ_BASE_URL="https://notify.eskiz.uz/api"

# --- Telegram ---------------------------------------------------------------
BOT_TOKEN=""
BACKEND_API_URL="http://backend:8000"
TELEGRAM_AUTH_SECRET=""

# --- Rate limiting ----------------------------------------------------------
RATE_LIMIT_AUTH="5/minute"
RATE_LIMIT_DEFAULT="100/minute"

# --- Monitoring -------------------------------------------------------------
SENTRY_DSN=""
SENTRY_TRACES_SAMPLE_RATE=0.1
