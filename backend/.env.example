# ─── Backend environment template ───────────────────────────────────────────
# For Docker deployments, use the ROOT .env.example instead.
# This file is for running the backend DIRECTLY (uv run uvicorn ...) outside Docker.
# Copy: cp .env.example .env   and fill in values.
# ─────────────────────────────────────────────────────────────────────────────

# --- Core -------------------------------------------------------------------
APP_NAME="ECommerce Platform"
DEBUG=false
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=CHANGE_ME_min32chars_random_string
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000"]
ALLOWED_HOSTS=["*"]

# --- Feature flags ----------------------------------------------------------
ELASTICSEARCH_ENABLED=false
TELEGRAM_BOT_ENABLED=true

# --- Superadmin (auto-created on first startup) -----------------------------
# Platforma birinchi ishga tushganda avtomatik yaratiladigan administrator.
ADMIN_EMAIL=admin@example.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123
ADMIN_FULL_NAME=Super Admin
# /admin/db — ma'lumotlar bazasini boshqarish UI (faqat DEBUG yoki bu yoqilganda)
SQLADMIN_ENABLED=false

# --- JWT --------------------------------------------------------------------
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000

# --- Database ---------------------------------------------------------------
# Local dev: sqlite+aiosqlite:///./dev.db
# Production: postgresql+asyncpg://user:pass@host:5432/dbname
DATABASE_URL=postgresql+asyncpg://ecommerce:CHANGE_ME@localhost:5432/ecommerce
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_ECHO=false

# --- Redis ------------------------------------------------------------------
REDIS_URL=redis://:CHANGE_ME_redis_password@localhost:6379/0
CART_TTL_SECONDS=604800

# --- RabbitMQ / Celery ------------------------------------------------------
CELERY_BROKER_URL=amqp://ecommerce:CHANGE_ME_rabbitmq_password@localhost:5672//
CELERY_RESULT_BACKEND=redis://:CHANGE_ME_redis_password@localhost:6379/1

# --- Storage (MinIO / S3) ---------------------------------------------------
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=CHANGE_ME_minio_access_key
MINIO_SECRET_KEY=CHANGE_ME_minio_secret_key
MINIO_BUCKET=ecommerce
MINIO_SECURE=false

# --- Payments ---------------------------------------------------------------
CLICK_SERVICE_ID=
CLICK_MERCHANT_ID=
CLICK_SECRET_KEY=
PAYME_ID=
PAYME_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Notifications ----------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@example.com
SMTP_TLS=true
ESKIZ_EMAIL=
ESKIZ_PASSWORD=

# --- Telegram ---------------------------------------------------------------
BOT_TOKEN=
TELEGRAM_AUTH_SECRET=
BACKEND_API_URL=http://backend:8000

# --- Rate limiting ----------------------------------------------------------
RATE_LIMIT_AUTH=5/minute
RATE_LIMIT_DEFAULT=100/minute

# --- Monitoring -------------------------------------------------------------
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
