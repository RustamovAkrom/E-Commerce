# ──────────────────────────────────────────────────────────────────────────
# Telegram bot environment template. Copy to `.env` and fill in.
# ──────────────────────────────────────────────────────────────────────────

# --- Telegram ---------------------------------------------------------------
# Get a token from @BotFather. Required to actually run the bot.
BOT_TOKEN=""
# Chat id that receives /support messages (your admin/group id).
ADMIN_CHAT_ID=0

# --- Backend ----------------------------------------------------------------
BACKEND_API_URL="http://backend:8000"
# Must equal the backend's TELEGRAM_AUTH_SECRET (see backend/.env).
TELEGRAM_AUTH_SECRET=""
REQUEST_TIMEOUT=15.0

# --- Redis (FSM storage, token cache, throttling) ---------------------------
REDIS_URL="redis://redis:6379/2"

# --- Runtime mode -----------------------------------------------------------
# dev  -> long polling (no public URL needed)
# prod -> webhook (requires WEBHOOK_BASE_URL below)
BOT_ENV="dev"

# --- Webhook (prod only) ----------------------------------------------------
WEBHOOK_BASE_URL=""                # e.g. https://shop.example.com
WEBHOOK_PATH="/telegram/webhook"
WEBHOOK_SECRET=""                  # random string; validates incoming updates
WEB_SERVER_HOST="0.0.0.0"
WEB_SERVER_PORT=8080

# --- Throttling -------------------------------------------------------------
THROTTLE_LIMIT=30
THROTTLE_WINDOW=60

# --- Auth-token cache -------------------------------------------------------
ACCESS_TOKEN_CACHE_TTL=780
